{
  "name": "screen-mirroring",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "check": "npm run check --workspaces --if-present",
    "dev:backend": "npm run dev --workspace @screen-mirroring/backend",
    "dev:sender": "npm run dev --workspace @screen-mirroring/dev-sender",
    "dev:web": "npm run dev --workspace @screen-mirroring/web-receiver"
  }
}

